@model WeddingApp.Models.Florist

@{
    ViewData["Title"] = "Florist Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Florist Details</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="card" style="max-width:600px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Arrangement Name</dt>
            <dd class="col-sm-8">@Model.ArrangementName</dd>

            <dt class="col-sm-4">Item</dt>
            <dd class="col-sm-8">@(Model.Item?.Name ?? "—")</dd>

            <dt class="col-sm-4">Partner</dt>
            <dd class="col-sm-8">@(Model.Partner?.Name ?? "—")</dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
    </div>
</div>
