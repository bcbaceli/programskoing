@model WeddingApp.Models.Band

@{
    ViewData["Title"] = "Delete Band";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Delete Band</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="alert alert-danger">
    Are you sure you want to delete <strong>@Model.Name</strong>? This action cannot be undone.
</div>

<div class="card" style="max-width:600px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>

            <dt class="col-sm-4">Partner</dt>
            <dd class="col-sm-8">@(Model.Partner?.Name ?? "—")</dd>

            <dt class="col-sm-4">Day of Week</dt>
            <dd class="col-sm-8">@Model.DayAtWeek</dd>

            <dt class="col-sm-4">Hours per Wedding</dt>
            <dd class="col-sm-8">@Model.HoursPerWedding</dd>

            <dt class="col-sm-4">Total Price</dt>
            <dd class="col-sm-8">@Model.TotalPrice</dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</div>
