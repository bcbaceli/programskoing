@model WeddingApp.ViewModels.ReportFormViewModel

@{
    ViewData["Title"] = "New Report";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>New Report</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="PartnerId" class="form-label"></label>
                <select asp-for="PartnerId" asp-items="Model.Partners" class="form-select">
                    <option value="">-- Select --</option>
                </select>
                <span asp-validation-for="PartnerId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="WeddingId" class="form-label">Wedding Ceremony</label>
                <select asp-for="WeddingId" asp-items="Model.WeddingCeremonies" class="form-select">
                    <option value="">-- Select --</option>
                </select>
                <span asp-validation-for="WeddingId" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Create</button>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
