@model WeddingApp.Models.WeddingCeremony

@{
    ViewData["Title"] = "Wedding Ceremony Details";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Wedding Ceremony Details</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="card" style="max-width:600px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Wedding Date</dt>
            <dd class="col-sm-8">@(Model.Wedding?.Date.ToString("d") ?? "—")</dd>

            <dt class="col-sm-4">Restaurant</dt>
            <dd class="col-sm-8">@(Model.Restaurant?.Name ?? "—")</dd>

            <dt class="col-sm-4">Band</dt>
            <dd class="col-sm-8">@(Model.Band?.Name ?? "—")</dd>

            <dt class="col-sm-4">Florist</dt>
            <dd class="col-sm-8">@(Model.Florist?.ArrangementName ?? "—")</dd>

            <dt class="col-sm-4">Price</dt>
            <dd class="col-sm-8">@Model.Price</dd>

            <dt class="col-sm-4">VAT</dt>
            <dd class="col-sm-8">@Model.VAT</dd>

            <dt class="col-sm-4">Total Price</dt>
            <dd class="col-sm-8">@Model.TotalPrice</dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
    </div>
</div>
