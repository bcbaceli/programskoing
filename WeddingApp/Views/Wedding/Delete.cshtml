@model WeddingApp.Models.Wedding

@{
    ViewData["Title"] = "Delete Wedding";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Delete Wedding</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="alert alert-danger">
    Are you sure you want to delete the wedding on <strong>@Model.Date.ToString("d")</strong>? This action cannot be undone.
</div>

<div class="card" style="max-width:600px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Date</dt>
            <dd class="col-sm-8">@Model.Date.ToString("d")</dd>

            <dt class="col-sm-4">Template</dt>
            <dd class="col-sm-8">@(Model.Template?.Name ?? "—")</dd>

            <dt class="col-sm-4">Address</dt>
            <dd class="col-sm-8">@(Model.Address ?? "—")</dd>

            <dt class="col-sm-4">Phone</dt>
            <dd class="col-sm-8">@(Model.Phone ?? "—")</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@(Model.Email ?? "—")</dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</div>
