@model IEnumerable<WeddingApp.Models.GenrePlaylist>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.GenreId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Genre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PlaylistId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Playlist)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.GenreId)
            </td>
            <td>
                @Html.DisplayFor(model => item.Genre)
            </td>
            <td>
                @Html.DisplayFor(model => item.PlaylistId)
            </td>
            <td>
                @Html.DisplayFor(model => item.Playlist)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
