@model WeddingApp.Models.Playlist

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Playlist</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="BandId" class="control-label"></label>
                <input asp-for="BandId" class="form-control" />
                <span asp-validation-for="BandId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Band" class="control-label"></label>
                <input asp-for="Band" class="form-control" />
                <span asp-validation-for="Band" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="GenrePlaylists" class="control-label"></label>
                <input asp-for="GenrePlaylists" class="form-control" />
                <span asp-validation-for="GenrePlaylists" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="SongPlaylists" class="control-label"></label>
                <input asp-for="SongPlaylists" class="form-control" />
                <span asp-validation-for="SongPlaylists" class="text-danger"></span>
            </div>
