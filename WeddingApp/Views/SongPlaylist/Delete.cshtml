@model WeddingApp.Models.SongPlaylist

@{
    ViewData["Title"] = "Delete Song Playlist";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Delete Song Playlist</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="alert alert-danger">
    Are you sure you want to delete this Song Playlist entry? This action cannot be undone.
</div>

<div class="card" style="max-width:600px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Song</dt>
            <dd class="col-sm-8">@(Model.Song?.Name ?? "—")</dd>

            <dt class="col-sm-4">Playlist</dt>
            <dd class="col-sm-8">@(Model.Playlist?.Name ?? "—")</dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</div>
